# ─────────────────────────────────────────────────────────
# Kubernetes Secrets (TEMPLATE - DO NOT COMMIT REAL VALUES)
# ─────────────────────────────────────────────────────────
# Create actual secrets with:
#   kubectl create secret generic blinkgo-secrets \
#     --from-literal=supabase-url='...' \
#     --from-literal=supabase-anon-key='...' \
#     --from-literal=supabase-service-role='...' \
#     --from-literal=app-url='https://app.blinkgo.com' \
#     --from-literal=google-maps-key='...' \
#     --from-literal=resend-key='...'
#
# Or use sealed-secrets / external-secrets for production.

apiVersion: v1
kind: Secret
metadata:
  name: blinkgo-secrets
  namespace: production
  annotations:
    # Sealed secrets key for SOPS
    sealedsecrets.bitnami.com/managed: "true"
type: Opaque
stringData:
  supabase-url: "REPLACE_ME"
  supabase-anon-key: "REPLACE_ME"
  supabase-service-role: "REPLACE_ME"
  app-url: "https://app.blinkgo.com"
  google-maps-key: "REPLACE_ME"
  resend-key: "REPLACE_ME"
